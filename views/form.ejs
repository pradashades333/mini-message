<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New message</title>
    <style>
        body {
            font-family: sans-serif;
            max-width: 600px;
            margin: 40px auto;
            padding: 0 20px;
            background-color: #ffe4f0;
            color: #7a1a4b;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        input, textarea {
            padding: 8px;
            font-size: 1rem;
            border: 1px solid #f4a8c7;
            border-radius: 4px;
            width: 100%;
            background-color: #fff0f7;
        }

        textarea {
            height: 100px;
            resize: vertical;
        }

        button {
            padding: 8px 16px;
            background: #c2185b;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            width: fit-content;
        }
    </style>
</head>
<body>
    <h1>New Message</h1>
    <form method="POST" action="/new">
        <label>Enter Username:</label>
        <input name="username" required>
        
        <label>Enter your message:</label>
        <textarea name="text" required></textarea>
        
        <button type="submit">Send</button>
    </form>
</body>
</html>