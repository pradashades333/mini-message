<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Message Page</title>
</head>
<body>
    <h1> message board</h1>

    <a href = "/new"> Write new msg</a>

    <% messages.forEach(function(message) { %>
        <div>
            <h3><%= message.user %> </h3>
            <p><%= message.text %></p>
            <small><%= message.added %></small>
        </div>
    <% }); %>
</body>
</html>
