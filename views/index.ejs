<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Message Page</title>
    <style>
        body {
            font-family: sans-serif;
            max-width: 600px;
            margin: 40px auto;
            padding: 0 20px;
            background-color: #ffe4f0;
            color: #7a1a4b;
        }

        h1 {
            border-bottom: 1px solid #f4a8c7;
            padding-bottom: 10px;
        }

        a {
            display: inline-block;
            margin-bottom: 20px;
            color: #c2185b;
        }
    </style>
</head>
<body>
    <h1> message board</h1>

    <a href = "/new"> Write new msg</a>

    <% messages.forEach(function(message) { %>
        <div>
            <h3><%= message.user %> </h3>
            <p><%= message.text %></p>
            <small><%= message.added %></small>
        </div>
    <% }); %>
</body>
</html>
